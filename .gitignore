# Terraform local directories and files
.terraform/
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Variable value files — may contain secrets
*.tfvars
*.tfvars.json

# Crash logs from Terraform
crash.log
crash.*.log

# Override files — used for local dev overrides, not committed
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform lock file with local provider paths (regenerated by init)
.terraform.lock.hcl
